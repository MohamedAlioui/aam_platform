{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "server/api/index.js": { "runtime": "@vercel/node" }
  },
  "rewrites": [
    { "source": "/api/:path*",       "destination": "/server/api/index.js" },
    { "source": "/socket.io/:path*", "destination": "/server/api/index.js" },
    { "source": "/:path*",           "destination": "/index.html" }
  ]
}
